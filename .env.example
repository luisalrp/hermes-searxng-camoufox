# ─────────────────────────────────────────────────────────────────────────
# Hermes + SearXNG + Camofox stack — environment configuration
# Copy this file to .env and fill in the values:   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────

# ── LLM provider (bring your own — Ollama is NOT bundled) ────────────────
# Hermes needs an LLM. Point it at a cloud API or an external OpenAI-compatible
# / Ollama endpoint. The exact variable names depend on your Hermes version —
# see https://hermes-agent.nousresearch.com/docs/user-guide/configuration
# OPENAI_BASE_URL=https://your-llm-endpoint/v1
# OPENAI_API_KEY=

# ── SearXNG (search backend) ─────────────────────────────────────────────
SEARXNG_VERSION=latest
# Host port the SearXNG UI/API is published on (generic compose only)
SEARXNG_PORT=8080
# Public base URL of this SearXNG instance
SEARXNG_BASE_URL=http://localhost:8080
# REQUIRED. Generate with:  openssl rand -hex 32
SEARXNG_SECRET=

# ── Camofox (stealth browser backend) ───────────────────────────────────
# Image: ghcr.io/jo-inc/camofox-browser  (multi-arch amd64/arm64).
# Published GHCR tags are app semver (e.g. 1.11.2) or "latest" — pin a version
# for reproducibility: https://github.com/jo-inc/camofox-browser/releases
# (The 135.0.1-<arch> form is only the local `make` build tag, not a GHCR tag.)
# NOTE: the CAMOFOX_* variable names are upstream literals (spelled without "u").
CAMOFOX_IMAGE_TAG=latest
CAMOFOX_MAX_OLD_SPACE_SIZE=1024
CAMOFOX_MAX_SESSIONS=10
CAMOFOX_MAX_TABS_PER_SESSION=5
CAMOFOX_SESSION_TIMEOUT_MS=1800000
CAMOFOX_BROWSER_IDLE_TIMEOUT_MS=300000
CAMOFOX_CRASH_REPORT_ENABLED=false

# ── Hermes Agent ─────────────────────────────────────────────────────────
HERMES_VERSION=latest
# Host port the Hermes OpenAI-compatible API is published on (generic compose only)
HERMES_API_PORT=8642
# REQUIRED. API key for the Hermes API server. Generate with:  openssl rand -hex 32
HERMES_API_SERVER_KEY=

# ── Firecrawl (extract backend) — NOT bundled in this stack ──────────────
# Hermes' web_extract defaults to Firecrawl, which this compose does not run.
# Either self-host Firecrawl (https://github.com/firecrawl/firecrawl, port 3002)
# and point Hermes at it, use a cloud key, or rely on SearXNG-only search.
# FIRECRAWL_API_URL=http://firecrawl:3002
# FIRECRAWL_API_KEY=
